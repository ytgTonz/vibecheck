{
  "name": "vibecheck",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "heroku-postbuild": "npm --workspace @vibecheck/api run build",
    "dev:landing": "npm --workspace @vibecheck/landing run dev",
    "build:landing": "npm --workspace @vibecheck/landing run build",
    "lint:landing": "npm --workspace @vibecheck/landing run lint",
    "preview:landing": "npm --workspace @vibecheck/landing run preview"
  },
  "dependencies": {
    "qrcode.react": "^4.2.0"
  }
}
