generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Venue {
  id         String    @id @default(cuid())
  name       String
  type       VenueType
  location   String
  city       String    @default("East London, Eastern Cape")
  hours       String?
  musicGenre  String[]
  coverCharge String?
  drinkPrices String?
  ownerId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  owner     User            @relation("OwnedVenues", fields: [ownerId], references: [id])
  promoters VenuePromoter[]
  invites   Invite[]
  streams   LiveStream[]
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VENUE_PROMOTER)
  createdAt DateTime @default(now())

  ownedVenues    Venue[]         @relation("OwnedVenues")
  venueLinks     VenuePromoter[]
  createdInvites Invite[]
  feedback       Feedback[]
  createdStreams  LiveStream[]    @relation("CreatedStreams")
  pushTokens     PushToken[]
  notifications  Notification[]
}

model VenuePromoter {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  venueId   String
  createdBy String
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id])
}

model Feedback {
  id        String           @id @default(cuid())
  category  FeedbackCategory
  rating    FeedbackRating
  message   String?
  userId    String
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum VenueType {
  NIGHTCLUB
  BAR
  RESTAURANT_BAR
  LOUNGE
  SHISA_NYAMA
  ROOFTOP
  OTHER
}

enum UserRole {
  VENUE_PROMOTER
  VENUE_OWNER
  ADMIN
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  GENERAL
}

enum FeedbackRating {
  BAD
  NEUTRAL
  GOOD
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
}

enum NotificationType {
  STREAM_LIVE
  STREAM_ENDED
  VENUE_CREATED
  USER_REGISTERED
  ATTENDANCE_INTENT
}

enum AttendanceType {
  INTENT
  ARRIVAL
}

// ─── Live Streaming ─────────────────────────────────────────────────────────

model LiveStream {
  id                 String       @id @default(cuid())
  venueId            String
  livekitRoom        String       @unique
  status             StreamStatus @default(IDLE)
  startedAt          DateTime?
  endedAt            DateTime?
  currentViewerCount Int          @default(0)
  viewerPeak         Int          @default(0)
  createdBy          String
  createdAt          DateTime     @default(now())

  venue      Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  creator    User               @relation("CreatedStreams", fields: [createdBy], references: [id])
  attendance StreamAttendance[]

  @@index([venueId, status])
  @@index([status])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model PushToken {
  id        String   @id @default(cuid())
  userId    String?
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  data      Json?
  userId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

// ─── Attendance Tracking ─────────────────────────────────────────────────────

model StreamAttendance {
  id        String         @id @default(cuid())
  streamId  String
  venueId   String
  deviceId  String
  userId    String?
  type      AttendanceType
  createdAt DateTime       @default(now())

  stream LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@unique([deviceId, streamId, type])
  @@index([streamId, type])
  @@index([venueId, createdAt])
}

model ScheduledNotification {
  id           String   @id @default(cuid())
  targetUserId String?
  title        String
  body         String
  data         Json?
  scheduledFor DateTime
  sent         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([sent, scheduledFor])
}
