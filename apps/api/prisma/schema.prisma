generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Venue {
  id         String    @id @default(cuid())
  name       String
  type       VenueType
  location   String
  city       String    @default("East London, Eastern Cape")
  hours       String?
  musicGenre  String[]
  coverCharge String?
  drinkPrices String?
  ownerId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  owner     User            @relation("OwnedVenues", fields: [ownerId], references: [id])
  clips     Clip[]
  promoters VenuePromoter[]
  invites   Invite[]
  streams   LiveStream[]
}

model Clip {
  id         String   @id @default(cuid())
  videoUrl   String
  thumbnail  String?
  duration   Int      // length of the clip in seconds
  venueId    String
  uploadedBy String   // user ID of the person who posted this
  musicGenre String?
  caption    String?
  views      Int      @default(0)
  createdAt  DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(VENUE_PROMOTER)
  createdAt DateTime @default(now())

  ownedVenues    Venue[]         @relation("OwnedVenues")
  venueLinks     VenuePromoter[]
  createdInvites Invite[]
  feedback       Feedback[]
  createdStreams  LiveStream[]    @relation("CreatedStreams")
}

model VenuePromoter {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  venueId   String
  createdBy String
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id])
}

model Feedback {
  id        String           @id @default(cuid())
  category  FeedbackCategory
  rating    FeedbackRating
  message   String?
  userId    String
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum VenueType {
  NIGHTCLUB
  BAR
  RESTAURANT_BAR
  LOUNGE
  SHISA_NYAMA
  ROOFTOP
  OTHER
}

enum UserRole {
  VENUE_PROMOTER
  VENUE_OWNER
  ADMIN
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  GENERAL
}

enum FeedbackRating {
  BAD
  NEUTRAL
  GOOD
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
}

// ─── Live Streaming ─────────────────────────────────────────────────────────

model LiveStream {
  id                 String       @id @default(cuid())
  venueId            String
  livekitRoom        String       @unique
  status             StreamStatus @default(IDLE)
  startedAt          DateTime?
  endedAt            DateTime?
  currentViewerCount Int          @default(0)
  viewerPeak         Int          @default(0)
  createdBy          String
  createdAt          DateTime     @default(now())

  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  creator User  @relation("CreatedStreams", fields: [createdBy], references: [id])

  @@index([venueId, status])
  @@index([status])
}
