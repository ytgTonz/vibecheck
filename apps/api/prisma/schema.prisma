generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Venue {
  id         String    @id @default(cuid())
  name       String
  type       VenueType
  location   String
  city       String    @default("")
  hours       String?
  musicGenre  String[]
  coverCharge String?
  drinkPrices String?
  ownerId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  owner     User            @relation("OwnedVenues", fields: [ownerId], references: [id])
  promoters VenuePromoter[]
  invites   Invite[]
  streams   LiveStream[]
  incentives VenueIncentive[]
  visits     VenueVisit[]
  qrTokens   AttendanceQRToken[]
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  password         String
  name             String
  role             UserRole @default(VENUE_PROMOTER)
  phone            String?
  emailVerified    Boolean  @default(false)
  phoneVerified    Boolean  @default(false)
  emailVerifyToken String?  @unique
  phoneOtp         String?  // TODO: hash before v2
  createdAt        DateTime @default(now())

  ownedVenues    Venue[]             @relation("OwnedVenues")
  venueLinks     VenuePromoter[]
  createdInvites Invite[]
  feedback       Feedback[]
  createdStreams  LiveStream[]        @relation("CreatedStreams")
  pushTokens     PushToken[]
  notifications  Notification[]
  venueVisits    VenueVisit[]
  qrTokens       AttendanceQRToken[]
}

model VenuePromoter {
  id        String   @id @default(cuid())
  userId    String
  venueId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([userId, venueId])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  venueId   String
  createdBy String
  used      Boolean   @default(false)
  usedBy    String?
  usedAt    DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  venue   Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)
  creator User  @relation(fields: [createdBy], references: [id])
}

model Feedback {
  id        String           @id @default(cuid())
  category  FeedbackCategory
  rating    FeedbackRating
  message   String?
  userId    String
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum VenueType {
  NIGHTCLUB
  BAR
  RESTAURANT_BAR
  LOUNGE
  SHISA_NYAMA
  ROOFTOP
  OTHER
}

enum UserRole {
  VENUE_PROMOTER
  VENUE_OWNER
  ADMIN
  VIEWER
}

enum FeedbackCategory {
  BUG
  SUGGESTION
  GENERAL
}

enum FeedbackRating {
  BAD
  NEUTRAL
  GOOD
}

enum StreamStatus {
  IDLE
  LIVE
  ENDED
}

enum NotificationType {
  STREAM_LIVE
  STREAM_ENDED
  VENUE_CREATED
  USER_REGISTERED
  ATTENDANCE_INTENT
}

enum AttendanceType {
  INTENT
  ARRIVAL
}

// ─── Live Streaming ─────────────────────────────────────────────────────────

model LiveStream {
  id                 String       @id @default(cuid())
  venueId            String
  livekitRoom        String       @unique
  status             StreamStatus @default(IDLE)
  startedAt          DateTime?
  endedAt            DateTime?
  currentViewerCount Int          @default(0)
  viewerPeak         Int          @default(0)
  createdBy          String
  createdAt          DateTime     @default(now())

  venue      Venue              @relation(fields: [venueId], references: [id], onDelete: Cascade)
  creator    User               @relation("CreatedStreams", fields: [createdBy], references: [id])
  attendance StreamAttendance[]

  @@index([venueId, status])
  @@index([status])
}

// ─── Notifications ──────────────────────────────────────────────────────────

model PushToken {
  id        String   @id @default(cuid())
  userId    String?
  token     String   @unique
  platform  String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  data      Json?
  userId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([createdAt])
}

// ─── Attendance Tracking ─────────────────────────────────────────────────────

model StreamAttendance {
  id        String         @id @default(cuid())
  streamId  String
  venueId   String
  deviceId  String
  userId    String?
  type      AttendanceType
  createdAt DateTime       @default(now())

  stream LiveStream @relation(fields: [streamId], references: [id], onDelete: Cascade)

  @@unique([deviceId, streamId, type])
  @@index([streamId, type])
  @@index([venueId, createdAt])
}

model ScheduledNotification {
  id           String   @id @default(cuid())
  targetUserId String?
  title        String
  body         String
  data         Json?
  scheduledFor DateTime
  sent         Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([sent, scheduledFor])
}

// ─── Venue Visit / QR Check-in ───────────────────────────────────────────────

model VenueIncentive {
  id          String    @id @default(cuid())
  venueId     String
  title       String
  description String
  expiresAt   DateTime?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  venue  Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  visits VenueVisit[]
  tokens AttendanceQRToken[]

  @@index([venueId, active])
}

model VenueVisit {
  id          String    @id @default(cuid())
  userId      String
  venueId     String
  streamId    String?
  intentAt    DateTime?
  arrivedAt   DateTime?
  incentiveId String?
  createdAt   DateTime  @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  incentive VenueIncentive? @relation(fields: [incentiveId], references: [id])
  qrToken   AttendanceQRToken?

  // Advisory only — Postgres does NOT enforce uniqueness for null streamId values.
  // Always use findFirst({ where: { userId, venueId, streamId: streamId ?? null } }) — never findUnique.
  @@unique([userId, venueId, streamId])
  @@index([venueId])
}

model AttendanceQRToken {
  id          String    @id @default(cuid())
  token       String    @unique
  userId      String
  venueId     String
  visitId     String    @unique
  incentiveId String?
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  venue     Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  visit     VenueVisit      @relation(fields: [visitId], references: [id], onDelete: Cascade)
  incentive VenueIncentive? @relation(fields: [incentiveId], references: [id])

  @@index([venueId, usedAt])
}
