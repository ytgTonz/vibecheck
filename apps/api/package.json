{
  "name": "@vibecheck/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "prisma migrate deploy && prisma generate && tsc",
    "test": "npm run build && node --test test/auth.test.mjs",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy",
    "seed": "ts-node-dev --transpile-only prisma/seed.ts",
    "seed:admin": "ts-node-dev --transpile-only prisma/seed-admin.ts",
    "db:reset": "ts-node-dev --transpile-only prisma/reset.ts"
  },
  "prisma": {
    "seed": "npm run seed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "expo-server-sdk": "^6.1.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "livekit-server-sdk": "^2.15.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "socket.io": "^4.8.3",
    "streamifier": "^0.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.11",
    "@types/streamifier": "^0.1.2",
    "prisma": "^7.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
